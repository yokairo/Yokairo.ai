rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{folder}/{fileName} {
      // Allow anyone to read, and allow authenticated (including anonymous) users to upload
      allow read: if true;
      allow write: if (folder in ['posters', 'profiles', 'avatars', 'clubs', 'club-banners'])
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
